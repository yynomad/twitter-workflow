# AI API 配置 - 火山方舟 Coding Plan

# 火山方舟 Coding Plan（正确配置）
VOLC_API_KEY=your-volc-api-key-here
VOLC_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
VOLC_MODEL=DeepSeek-V3.2

# Telegram Bot 配置
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# 当前使用的 AI 服务
AI_PROVIDER=volc

# Twitter 搜索配置（默认值，可被命令行参数覆盖）
# 优先级：命令行参数 > 环境变量 > config.json
TWITTER_SEARCH_QUERY=""
TWITTER_MIN_LIKES=0
TWITTER_MIN_RETWEETS=0
TWITTER_MIN_VIEWS=0
TWITTER_HOURS=0
TWITTER_EXCLUDE_REPLIES=false
TWITTER_EXCLUDE_RETWEETS=false
TWITTER_NUM_TWEETS=1
TWITTER_SELECTION_MODE=random
