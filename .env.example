# AI API 配置示例

# 选项 1：火山引擎（需要激活模型服务）
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLC_API_KEY=your-volc-api-key-here
# VOLC_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# VOLC_MODEL=doubao-pro-4k

# 选项 2：DeepSeek（推荐，无需激活）
# 获取地址：https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 当前使用的 AI 服务
AI_PROVIDER=deepseek

# Telegram Bot 配置
# 创建机器人：@BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Twitter 配置（Playwright 版本不需要 API Key）
# 只需运行 python login_twitter.py 登录即可
